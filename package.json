{
  "name": "riceflow-erp",
  "version": "0.1.0",
  "private": true,
  "description": "RICEFLOW ERP — Enterprise Rice Industry Management Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix apps/backend run start:dev",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --prefix apps/backend run build",
    "build:frontend": "npm --prefix apps/frontend run build",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm --prefix apps/backend run lint",
    "lint:frontend": "npm --prefix apps/frontend run lint",
    "typecheck": "npm run typecheck:frontend",
    "typecheck:frontend": "npm --prefix apps/frontend run typecheck",
    "db:generate": "npm --prefix apps/backend run db:generate",
    "db:migrate": "npm --prefix apps/backend run db:migrate",
    "db:seed": "npm --prefix apps/backend run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "rm -rf apps/backend/dist apps/frontend/.next"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
