  settlementId      String?          @map("settlement_id") @db.Uuid
  date              DateTime         @db.Date
  createdAt         DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, partyId])
  @@map("commission_entries")
}

model Settlement {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  settlementNumber String           @map("settlement_number")
  partyType        String           @map("party_type")
  partyId          String           @map("party_id") @db.Uuid
  partyName        String           @map("party_name")
