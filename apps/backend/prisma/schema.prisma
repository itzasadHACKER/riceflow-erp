model FreightEntry {
  id                String        @id @default(uuid()) @db.Uuid
  organizationId    String        @map("organization_id") @db.Uuid
  date              DateTime      @db.Date
  vehicleId         String?       @map("vehicle_id") @db.Uuid
  driverId          String?       @map("driver_id") @db.Uuid
  fromLocation      String        @map("from_location")
  toLocation        String        @map("to_location")
  distance          Decimal?      @db.Decimal(10, 2)
  freightAmount     Decimal       @map("freight_amount") @db.Decimal(18, 4)
  loadingCharges    Decimal       @default(0) @map("loading_charges") @db.Decimal(18, 4)
  unloadingCharges  Decimal       @default(0) @map("unloading_charges") @db.Decimal(18, 4)
  totalAmount       Decimal       @map("total_amount") @db.Decimal(18, 4)
  referenceType     String?       @map("reference_type")
  referenceId       String?       @map("reference_id") @db.Uuid
  paymentStatus     PaymentStatus @default(UNPAID) @map("payment_status")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id])
  driver       Driver?      @relation(fields: [driverId], references: [id])

  @@index([organizationId, date])
  @@map("freight_entries")
}

