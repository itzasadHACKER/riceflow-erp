// QUOTATIONS
// ============================================================================

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quotation {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  quotationNumber String         @map("quotation_number")
  date           DateTime        @db.Date
  validUntil     DateTime?       @map("valid_until") @db.Date
  customerId     String          @map("customer_id") @db.Uuid
  totalAmount    Decimal         @default(0) @map("total_amount") @db.Decimal(18, 4)
  discount       Decimal         @default(0) @db.Decimal(18, 4)
  taxAmount      Decimal         @default(0) @map("tax_amount") @db.Decimal(18, 4)
  netAmount      Decimal         @default(0) @map("net_amount") @db.Decimal(18, 4)
  terms          String?
  narration      String?
  status         QuotationStatus @default(DRAFT)
  salesOrderId   String?         @map("sales_order_id") @db.Uuid
  createdBy      String?         @map("created_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
