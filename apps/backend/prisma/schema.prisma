// ============================================================================
// EXPORT SALES / LC MANAGEMENT
// ============================================================================

enum LCStatus {
  DRAFT_LC
  OPENED
  CONFIRMED
  SHIPPED
  NEGOTIATED
  SETTLED_LC
  EXPIRED_LC
  CANCELLED_LC
}

model ExportContract {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  contractNumber String   @map("contract_number")
  customerId     String   @map("customer_id") @db.Uuid
  buyerName      String   @map("buyer_name")
  buyerCountry   String   @map("buyer_country")
  riceVarietyId  String?  @map("rice_variety_id") @db.Uuid
  quantity       Decimal  @db.Decimal(18, 4)
  unit           String   @default("MT")
  pricePerUnit   Decimal  @map("price_per_unit") @db.Decimal(18, 4)
  currency       String   @default("USD")
  totalValue     Decimal  @map("total_value") @db.Decimal(18, 4)
  incoterm       String?
  portOfLoading  String?  @map("port_of_loading")
  portOfDischarge String? @map("port_of_discharge")
  shipmentDate   DateTime? @map("shipment_date") @db.Date
  expiryDate     DateTime? @map("expiry_date") @db.Date
  status         String   @default("DRAFT")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  letterOfCredits LetterOfCredit[]
  shippingDocs    ShippingDocument[]

  @@unique([organizationId, contractNumber])
  @@index([organizationId])
  @@map("export_contracts")
}

model LetterOfCredit {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  exportContractId  String   @map("export_contract_id") @db.Uuid
  lcNumber          String   @map("lc_number")
  issuingBank       String   @map("issuing_bank")
  advisingBank      String?  @map("advising_bank")
  amount            Decimal  @db.Decimal(18, 4)
  currency          String   @default("USD")
  issueDate         DateTime @map("issue_date") @db.Date
  expiryDate        DateTime @map("expiry_date") @db.Date
  shipmentDeadline  DateTime? @map("shipment_deadline") @db.Date
  status            LCStatus @default(DRAFT_LC)
  terms             String?  @db.Text
  documents         Json     @default("[]")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  exportContract ExportContract @relation(fields: [exportContractId], references: [id])

  @@unique([organizationId, lcNumber])
  @@map("letters_of_credit")
}

model ShippingDocument {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  exportContractId String   @map("export_contract_id") @db.Uuid
  documentType     String   @map("document_type")
  documentNumber   String   @map("document_number")
