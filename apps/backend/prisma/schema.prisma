// ============================================================================
// PURCHASE ORDERS & GOODS RECEIPT
// ============================================================================

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  orderNumber    String              @map("order_number")
  date           DateTime            @db.Date
  supplierId     String              @map("supplier_id") @db.Uuid
  branchId       String?             @map("branch_id") @db.Uuid
  totalAmount    Decimal             @default(0) @map("total_amount") @db.Decimal(18, 4)
  discount       Decimal             @default(0) @db.Decimal(18, 4)
  taxAmount      Decimal             @default(0) @map("tax_amount") @db.Decimal(18, 4)
  netAmount      Decimal             @default(0) @map("net_amount") @db.Decimal(18, 4)
  expectedDate   DateTime?           @map("expected_date") @db.Date
  terms          String?
  narration      String?
  status         PurchaseOrderStatus @default(DRAFT)
  createdBy      String?             @map("created_by") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  items         PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, date])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String  @map("purchase_order_id") @db.Uuid
  riceVarietyId   String  @map("rice_variety_id") @db.Uuid
  quantity        Decimal @db.Decimal(18, 4)
  unit            String  @default("KG")
  rate            Decimal @db.Decimal(18, 4)
  amount          Decimal @db.Decimal(18, 4)
  receivedQty     Decimal @default(0) @map("received_qty") @db.Decimal(18, 4)
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  riceVariety   RiceVariety   @relation(fields: [riceVarietyId], references: [id])

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model GoodsReceipt {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  receiptNumber   String        @map("receipt_number")
  date            DateTime      @db.Date
  purchaseOrderId String?       @map("purchase_order_id") @db.Uuid
  supplierId      String        @map("supplier_id") @db.Uuid
  warehouseId     String        @map("warehouse_id") @db.Uuid
  totalQuantity   Decimal       @map("total_quantity") @db.Decimal(18, 4)
  inspectionStatus String?      @map("inspection_status")
  notes           String?
  narration       String?
  createdBy       String?       @map("created_by") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  items         GoodsReceiptItem[]

  @@unique([organizationId, receiptNumber])
  @@index([organizationId, date])
  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id             String  @id @default(uuid()) @db.Uuid
  goodsReceiptId String  @map("goods_receipt_id") @db.Uuid
  riceVarietyId  String  @map("rice_variety_id") @db.Uuid
  quantity       Decimal @db.Decimal(18, 4)
  unit           String  @default("KG")
  lotNumber      String? @map("lot_number")
  qualityGrade   QualityGrade? @map("quality_grade")
  moisture       Decimal? @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  riceVariety  RiceVariety  @relation(fields: [riceVarietyId], references: [id])

  @@index([goodsReceiptId])
  @@map("goods_receipt_items")
}

