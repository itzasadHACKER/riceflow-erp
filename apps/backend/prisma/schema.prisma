// ===================== GATE PASS =====================

enum GatePassType {
  OUTGOING
  INCOMING
  VISITOR
}

enum GatePassStatus {
  DRAFT
  APPROVED
  CHECKED_OUT
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum OutgoingCategory {
  RICE_SALE
  MACHINERY
  SAMPLES
  OFFICE_EQUIPMENT
  STATIONERY
  ELECTRICAL
  WASTE_DISPOSAL
  MISCELLANEOUS
}

enum IncomingCategory {
  PADDY
  GROCERY
  MACHINERY
  STATIONERY
  ELECTRICAL_EQUIPMENT
  OFFICE_EQUIPMENT
  RAW_MATERIAL
  SPARE_PARTS
  FUEL
  MISCELLANEOUS
}

model GatePass {
  id               String          @id @default(uuid()) @db.Uuid
  organizationId   String          @map("organization_id") @db.Uuid
  gatePassNumber   String          @map("gate_pass_number")
  type             GatePassType
  status           GatePassStatus  @default(DRAFT)
  date             DateTime        @default(now())
  // Common fields
  vehicleNumber    String?         @map("vehicle_number")
  driverName       String?         @map("driver_name")
  driverPhone      String?         @map("driver_phone")
  remarks          String?
  approvedById     String?         @map("approved_by_id") @db.Uuid
  approvedAt       DateTime?       @map("approved_at")
  checkOutTime     DateTime?       @map("check_out_time")
  checkInTime      DateTime?       @map("check_in_time")
  // Outgoing-specific
  outgoingCategory OutgoingCategory? @map("outgoing_category")
  customerId       String?          @map("customer_id") @db.Uuid
  salesOrderId     String?          @map("sales_order_id") @db.Uuid
  deliveryChallanId String?         @map("delivery_challan_id") @db.Uuid
  // Incoming-specific
  incomingCategory IncomingCategory? @map("incoming_category")
  supplierId       String?           @map("supplier_id") @db.Uuid
  purchaseOrderId  String?           @map("purchase_order_id") @db.Uuid
  // Visitor-specific
  visitorName      String?          @map("visitor_name")
  visitorPhone     String?          @map("visitor_phone")
  visitorCompany   String?          @map("visitor_company")
  visitorEmail     String?          @map("visitor_email")
  visitorIdType    String?          @map("visitor_id_type")
  visitorIdNumber  String?          @map("visitor_id_number")
  personToMeet     String?          @map("person_to_meet")
  department       String?
  purpose          String?
  expectedDuration String?          @map("expected_duration")
  badgeNumber      String?          @map("badge_number")

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvedBy       User?            @relation("GatePassApprover", fields: [approvedById], references: [id])
  items            GatePassItem[]

  @@unique([organizationId, gatePassNumber])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@map("gate_passes")
}

model GatePassItem {
  id          String  @id @default(uuid()) @db.Uuid
  gatePassId  String  @map("gate_pass_id") @db.Uuid
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unit        String  @default("KG")
  weight      Decimal? @db.Decimal(18, 4)
  value       Decimal? @db.Decimal(18, 4)
  serialNumber String? @map("serial_number")
  remarks     String?
  createdAt   DateTime @default(now()) @map("created_at")

  gatePass    GatePass @relation(fields: [gatePassId], references: [id], onDelete: Cascade)

  @@map("gate_pass_items")
}

