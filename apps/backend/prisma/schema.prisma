  @@index([quotationId])
  @@map("quotation_items")
}

// ============================================================================
// FIXED ASSETS
// ============================================================================

enum AssetStatus {
  ACTIVE
  DISPOSED
  WRITTEN_OFF
  UNDER_MAINTENANCE
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  DOUBLE_DECLINING
  UNITS_OF_PRODUCTION
}

model FixedAsset {
  id                  String             @id @default(uuid()) @db.Uuid
  organizationId      String             @map("organization_id") @db.Uuid
  assetCode           String             @map("asset_code")
  name                String
  description         String?
  category            String
  location            String?
  branchId            String?            @map("branch_id") @db.Uuid
  purchaseDate        DateTime           @map("purchase_date") @db.Date
  purchasePrice       Decimal            @map("purchase_price") @db.Decimal(18, 4)
  salvageValue        Decimal            @default(0) @map("salvage_value") @db.Decimal(18, 4)
  usefulLifeYears     Int                @map("useful_life_years")
  depreciationMethod  DepreciationMethod @default(STRAIGHT_LINE) @map("depreciation_method")
  accumulatedDepr     Decimal            @default(0) @map("accumulated_depr") @db.Decimal(18, 4)
  currentValue        Decimal            @map("current_value") @db.Decimal(18, 4)
  assetAccountId      String?            @map("asset_account_id") @db.Uuid
  deprExpenseAccountId String?           @map("depr_expense_account_id") @db.Uuid
  accumDeprAccountId  String?            @map("accum_depr_account_id") @db.Uuid
  status              AssetStatus        @default(ACTIVE)
  disposalDate        DateTime?          @map("disposal_date") @db.Date
  disposalAmount      Decimal?           @map("disposal_amount") @db.Decimal(18, 4)
  serialNumber        String?            @map("serial_number")
  warrantyExpiry      DateTime?          @map("warranty_expiry") @db.Date
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  deletedAt           DateTime?          @map("deleted_at")

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  depreciations  AssetDepreciation[]

  @@unique([organizationId, assetCode])
  @@index([organizationId])
  @@map("fixed_assets")
}

model AssetDepreciation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  assetId        String   @map("asset_id") @db.Uuid
  period         String
  date           DateTime @db.Date
  amount         Decimal  @db.Decimal(18, 4)
  accumulatedTotal Decimal @map("accumulated_total") @db.Decimal(18, 4)
  bookValue      Decimal  @map("book_value") @db.Decimal(18, 4)
  journalEntryId String?  @map("journal_entry_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        FixedAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([assetId])
  @@map("asset_depreciations")
}

// ============================================================================
// QUALITY CONTROL
// ============================================================================

enum InspectionStatus {
  PENDING_INSPECTION
  PASSED
  FAILED
  CONDITIONAL
}

model QualityInspection {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  inspectionNumber String           @map("inspection_number")
  date             DateTime         @db.Date
  referenceType    String           @map("reference_type")
  referenceId      String           @map("reference_id") @db.Uuid
  riceVarietyId    String?          @map("rice_variety_id") @db.Uuid
  lotNumber        String?          @map("lot_number")
  sampleSize       Decimal?         @map("sample_size") @db.Decimal(18, 4)
  moisture         Decimal?         @db.Decimal(5, 2)
  brokenPercentage Decimal?         @map("broken_percentage") @db.Decimal(5, 2)
  foreignMatter    Decimal?         @map("foreign_matter") @db.Decimal(5, 2)
  chalkyGrains     Decimal?         @map("chalky_grains") @db.Decimal(5, 2)
  damagedGrains    Decimal?         @map("damaged_grains") @db.Decimal(5, 2)
  discolored       Decimal?         @db.Decimal(5, 2)
  grainLength      Decimal?         @map("grain_length") @db.Decimal(5, 2)
  grainWidth       Decimal?         @map("grain_width") @db.Decimal(5, 2)
  aroma            String?
  cookingQuality   String?          @map("cooking_quality")
  grade            QualityGrade?
  status           InspectionStatus @default(PENDING_INSPECTION)
  inspectedBy      String?          @map("inspected_by") @db.Uuid
  remarks          String?
  certificateNumber String?         @map("certificate_number")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, inspectionNumber])
  @@index([organizationId, date])
  @@index([referenceType, referenceId])
  @@map("quality_inspections")
}

// ============================================================================
// BANK MANAGEMENT
// ============================================================================

enum ReconciliationStatus {
  PENDING_RECONCILIATION
  MATCHED
  UNMATCHED
  PARTIALLY_MATCHED
}

enum ChequeStatus {
  ISSUED
  CLEARED
  BOUNCED
  CANCELLED
  DEPOSITED
  RETURNED
}

model BankReconciliation {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  bankAccountId  String               @map("bank_account_id") @db.Uuid
  date           DateTime             @db.Date
  statementDate  DateTime             @map("statement_date") @db.Date
  description    String?
  debit          Decimal              @default(0) @db.Decimal(18, 4)
  credit         Decimal              @default(0) @db.Decimal(18, 4)
  balance        Decimal              @default(0) @db.Decimal(18, 4)
  referenceNumber String?             @map("reference_number")
  status         ReconciliationStatus @default(PENDING_RECONCILIATION)
  matchedEntryId String?              @map("matched_entry_id") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount  @relation(fields: [bankAccountId], references: [id])

  @@index([organizationId, bankAccountId])
  @@map("bank_reconciliations")
}

model Cheque {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  bankAccountId  String       @map("bank_account_id") @db.Uuid
  chequeNumber   String       @map("cheque_number")
  date           DateTime     @db.Date
  amount         Decimal      @db.Decimal(18, 4)
  payee          String?
  issuedTo       String?      @map("issued_to")
  partyType      String?      @map("party_type")
  partyId        String?      @map("party_id") @db.Uuid
  status         ChequeStatus @default(ISSUED)
  clearanceDate  DateTime?    @map("clearance_date") @db.Date
  bounceReason   String?      @map("bounce_reason")
  narration      String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount  @relation(fields: [bankAccountId], references: [id])

  @@index([organizationId, bankAccountId])
  @@map("cheques")
}

// ============================================================================
// EXPENSE CATEGORIES
// ============================================================================

model ExpenseCategory {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  code           String
  description    String?
  accountId      String? @map("account_id") @db.Uuid
  parentId       String? @map("parent_id") @db.Uuid
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ExpenseCategory?  @relation("ExpenseCategoryTree", fields: [parentId], references: [id])
  children     ExpenseCategory[] @relation("ExpenseCategoryTree")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("expense_categories")
}

// ============================================================================
// BILL OF MATERIALS & WORK ORDERS
// ============================================================================

enum WorkOrderStatus {
  DRAFT_WO
  RELEASED
  IN_PROGRESS_WO
  COMPLETED_WO
  CANCELLED_WO
}

model BillOfMaterial {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  code           String
  outputVarietyId String @map("output_variety_id") @db.Uuid
  outputQuantity Decimal @map("output_quantity") @db.Decimal(18, 4)
  processType    ProcessType @map("process_type")
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outputVariety RiceVariety         @relation("BOMOutput", fields: [outputVarietyId], references: [id])
  items         BillOfMaterialItem[]
  workOrders    WorkOrder[]

  @@unique([organizationId, code])
  @@map("bill_of_materials")
}

model BillOfMaterialItem {
  id          String  @id @default(uuid()) @db.Uuid
  bomId       String  @map("bom_id") @db.Uuid
  riceVarietyId String @map("rice_variety_id") @db.Uuid
  quantity    Decimal @db.Decimal(18, 4)
  unit        String  @default("KG")
  createdAt   DateTime @default(now()) @map("created_at")

  bom         BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  riceVariety RiceVariety    @relation("BOMInput", fields: [riceVarietyId], references: [id])

  @@index([bomId])
  @@map("bom_items")
}

model WorkOrder {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  orderNumber    String          @map("order_number")
  date           DateTime        @db.Date
  bomId          String          @map("bom_id") @db.Uuid
  plannedQuantity Decimal        @map("planned_quantity") @db.Decimal(18, 4)
  actualQuantity Decimal?        @map("actual_quantity") @db.Decimal(18, 4)
  startDate      DateTime?       @map("start_date") @db.Date
  endDate        DateTime?       @map("end_date") @db.Date
  warehouseId    String?         @map("warehouse_id") @db.Uuid
  status         WorkOrderStatus @default(DRAFT_WO)
  notes          String?
  createdBy      String?         @map("created_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bom          BillOfMaterial @relation(fields: [bomId], references: [id])

  @@unique([organizationId, orderNumber])
  @@index([organizationId, date])
  @@map("work_orders")
}

// ============================================================================
// DATA IMPORT & EXPORT
// ============================================================================

enum ImportStatus {
  PENDING_IMPORT
  PROCESSING
  COMPLETED_IMPORT
  FAILED_IMPORT
  PARTIALLY_COMPLETED
}

model DataImportLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  importType     String       @map("import_type")
  fileName       String       @map("file_name")
  totalRows      Int          @map("total_rows")
  successRows    Int          @default(0) @map("success_rows")
  failedRows     Int          @default(0) @map("failed_rows")
  errors         Json?
  status         ImportStatus @default(PENDING_IMPORT)
  importedBy     String?      @map("imported_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  completedAt    DateTime?    @map("completed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("data_import_logs")
}

// ============================================================================
// PRINT TEMPLATES & NUMBERING
// ============================================================================

model PrintTemplate {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  entityType     String  @map("entity_type")
  template       String  @db.Text
  isDefault      Boolean @default(false) @map("is_default")
  paperSize      String  @default("A4") @map("paper_size")
  orientation    String  @default("portrait")
  headerHtml     String? @map("header_html") @db.Text
  footerHtml     String? @map("footer_html") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType])
  @@map("print_templates")
}

model NumberingSeries {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  entityType     String  @map("entity_type")
  prefix         String
  currentNumber  Int     @default(0) @map("current_number")
  padLength      Int     @default(6) @map("pad_length")
  suffix         String?
  fiscalYearId   String? @map("fiscal_year_id") @db.Uuid
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType])
  @@index([organizationId])
  @@map("numbering_series")
}
