// ============================================================================
// PRODUCTION MANAGEMENT
// ============================================================================

enum ProcessType {
  SHELLING
  POLISHING
  SELLA
  STEAM
  SORTING
  GRADING
  CLEANING
}

enum BatchStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionBatch {
  id              String      @id @default(uuid()) @db.Uuid
  organizationId  String      @map("organization_id") @db.Uuid
  branchId        String      @map("branch_id") @db.Uuid
  batchNumber     String      @map("batch_number")
  date            DateTime    @db.Date
  inputVarietyId  String      @map("input_variety_id") @db.Uuid
  inputLotNumber  String?     @map("input_lot_number")
  inputWeight     Decimal     @map("input_weight") @db.Decimal(18, 4)
  processType     ProcessType @map("process_type")
  status          BatchStatus @default(PLANNED)
  startedAt       DateTime?   @map("started_at")
  completedAt     DateTime?   @map("completed_at")
  notes           String?
  createdBy       String?     @map("created_by") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch             @relation(fields: [branchId], references: [id])
  inputVariety RiceVariety        @relation("InputVariety", fields: [inputVarietyId], references: [id])
  outputs      ProductionOutput[]
  costs        ProductionCost[]
  millingRecords MillingRecord[]

  @@unique([organizationId, batchNumber])
  @@index([organizationId, date])
  @@map("production_batches")
}

model ProductionOutput {
  id                  String       @id @default(uuid()) @db.Uuid
  batchId             String       @map("batch_id") @db.Uuid
  outputVarietyId     String       @map("output_variety_id") @db.Uuid
  outputWeight        Decimal      @map("output_weight") @db.Decimal(18, 4)
  recoveryPercentage  Decimal?     @map("recovery_percentage") @db.Decimal(5, 2)
  grade               QualityGrade?
  lotNumber           String?      @map("lot_number")
  notes               String?
  createdAt           DateTime     @default(now()) @map("created_at")

  batch         ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  outputVariety RiceVariety     @relation("OutputVariety", fields: [outputVarietyId], references: [id])

  @@index([batchId])
  @@map("production_outputs")
}

model ProductionCost {
  id          String  @id @default(uuid()) @db.Uuid
  batchId     String  @map("batch_id") @db.Uuid
  costType    String  @map("cost_type")
  description String?
  amount      Decimal @db.Decimal(18, 4)
  createdAt   DateTime @default(now()) @map("created_at")

  batch ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("production_costs")
}

model MillingRecord {
  id                  String  @id @default(uuid()) @db.Uuid
  batchId             String  @map("batch_id") @db.Uuid
  paddyInputWeight    Decimal @map("paddy_input_weight") @db.Decimal(18, 4)
  riceOutputWeight    Decimal @map("rice_output_weight") @db.Decimal(18, 4)
  brokenOutputWeight  Decimal @default(0) @map("broken_output_weight") @db.Decimal(18, 4)
  huskWeight          Decimal @default(0) @map("husk_weight") @db.Decimal(18, 4)
  branWeight          Decimal @default(0) @map("bran_weight") @db.Decimal(18, 4)
  recoveryPercentage  Decimal? @map("recovery_percentage") @db.Decimal(5, 2)
  brokenRatio         Decimal? @map("broken_ratio") @db.Decimal(5, 2)
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  batch ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("milling_records")
}

