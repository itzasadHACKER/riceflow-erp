  subject        String?
  content        String?
  loggedBy       String?              @map("logged_by") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  followUps    FollowUp[]

  @@index([organizationId])
  @@index([contactType, contactId])
  @@map("communication_logs")
}

model FollowUp {
  id                 String         @id @default(uuid()) @db.Uuid
  communicationLogId String         @map("communication_log_id") @db.Uuid
  dueDate            DateTime       @map("due_date") @db.Date
  status             FollowUpStatus @default(PENDING)
  assignedTo         String?        @map("assigned_to") @db.Uuid
  notes              String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  communicationLog CommunicationLog @relation(fields: [communicationLogId], references: [id], onDelete: Cascade)

  @@index([communicationLogId])
  @@map("follow_ups")
}

