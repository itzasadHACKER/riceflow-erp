generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ORGANIZATION & AUTH
// ============================================================================

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Organization {
  id               String           @id @default(uuid()) @db.Uuid
  name             String
  slug             String           @unique
  logoUrl          String?          @map("logo_url")
  address          String?
  city             String?
  state            String?
  country          String?          @default("Pakistan")
  phone            String?
  email            String?
  website          String?
  taxId            String?          @map("tax_id")
  registrationNo   String?          @map("registration_no")
  subscriptionTier SubscriptionTier @default(FREE) @map("subscription_tier")
  settings         Json?            @default("{}")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  branches           Branch[]
  departments        Department[]
  users              User[]
  roles              Role[]
  employees          Employee[]
  fiscalYears        FiscalYear[]
  chartOfAccounts    ChartOfAccount[]
  journalEntries     JournalEntry[]
  bankAccounts       BankAccount[]
  paymentVouchers    PaymentVoucher[]
  receiptVouchers    ReceiptVoucher[]
  taxConfigurations  TaxConfiguration[]
  suppliers          Supplier[]
  riceVarieties      RiceVariety[]
  paddyPurchases     PaddyPurchase[]
  purchaseRates      PurchaseRate[]
  productionBatches  ProductionBatch[]
  warehouses         Warehouse[]
  inventoryItems     InventoryItem[]
  stockMovements     StockMovement[]
  customers          Customer[]
  salesOrders        SalesOrder[]
  salesInvoices      SalesInvoice[]
  deliveryChallans   DeliveryChallan[]
  vehicles           Vehicle[]
  drivers            Driver[]
  freightEntries     FreightEntry[]
  leads              Lead[]
  brokers            Broker[]
  communicationLogs  CommunicationLog[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  systemSettings     SystemSetting[]
  fileAttachments    FileAttachment[]
  leaveTypes         LeaveType[]
  expenseClaims      ExpenseClaim[]
  stockAdjustments   StockAdjustment[]
  creditNotes        CreditNote[]
  debitNotes         DebitNote[]
  purchaseReturns    PurchaseReturn[]
  salesReturns       SalesReturn[]
  fixedAssets        FixedAsset[]
  assetDepreciations AssetDepreciation[]
  qualityInspections QualityInspection[]
  bankReconciliations BankReconciliation[]
  cheques            Cheque[]
  expenseCategories  ExpenseCategory[]
  purchaseOrders     PurchaseOrder[]
  goodsReceipts      GoodsReceipt[]
  quotations         Quotation[]
  billOfMaterials    BillOfMaterial[]
  workOrders         WorkOrder[]
  dataImportLogs     DataImportLog[]
  printTemplates     PrintTemplate[]
  numberingSeries    NumberingSeries[]
  workflowDefinitions WorkflowDefinition[]
  workflowInstances  WorkflowInstance[]
  workflowApprovals  WorkflowApproval[]
  budgets            Budget[]
  machines           Machine[]
  maintenanceLogs    MaintenanceLog[]
  machineSpares      MachineSpare[]
  downtimeLogs       DowntimeLog[]
  documents          Document[]
  contracts          Contract[]
  currencies         Currency[]
  exchangeRates      ExchangeRate[]
  commissionRules    CommissionRule[]
  commissionEntries  CommissionEntry[]
  settlements        Settlement[]
  marketRates        MarketRate[]
  employeeDocuments  EmployeeDocument[]
  employeeLoans      EmployeeLoan[]
  performanceReviews PerformanceReview[]
  finalSettlements   FinalSettlement[]
  warehouseZones     WarehouseZone[]
  warehouseBins      WarehouseBin[]
  cycleCounts        CycleCount[]
  stockReservations  StockReservation[]
  productionPlans    ProductionPlan[]
  meetings           Meeting[]
  fuelLogs           FuelLog[]
  routes             Route[]
  customFields       CustomField[]
  customFieldValues  CustomFieldValue[]
  exportContracts    ExportContract[]
  lettersOfCredit    LetterOfCredit[]
  shippingDocuments  ShippingDocument[]
  aiConversations    AiConversation[]
  integrationConfigs IntegrationConfig[]
  scheduledJobs      ScheduledJob[]
  currency           String?          @default("PKR")
  letterheadUrl      String?          @map("letterhead_url")
  termsAndConditions String?          @map("terms_and_conditions") @db.Text
  emailServerConfigs EmailServerConfig[]
  emailMessages      EmailMessage[]
  conversations      Conversation[]
  contactGroups      ContactGroup[]
  announcements      Announcement[]
  setupProgress      SetupProgress[]
  experienceLetters  ExperienceLetterTemplate[]
  gatePasses         GatePass[]
  salespersons       Salesperson[]
  salespersonSalesTransactions SalespersonSalesTransaction[]
  productCategories  ProductCategory[]
  serviceCalls       ServiceCall[]
  serviceContracts   ServiceContract[]
  equipmentCards     EquipmentCard[]
  projects           Project[]
  timesheets         Timesheet[]
  mrpRuns            MrpRun[]
  demandForecasts    DemandForecast[]
  salesQuotations    SalesQuotation[]
  blanketAgreements  BlanketAgreement[]
  priceLists         PriceList[]
  discountGroups     DiscountGroup[]
  specialPrices      SpecialPrice[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseQuotations PurchaseQuotation[]
  batchRecords       BatchRecord[]
  serialNumbers      SerialNumber[]
  pickLists          PickList[]
  packingLists       PackingList[]
  costCenters        CostCenter[]
  paymentRuns        PaymentRun[]
  dunningLevels      DunningLevel[]
  dunningRuns        DunningRun[]
  marketingCampaigns MarketingCampaign[]
  financialPeriods   FinancialPeriod[]
  withholdingTaxConfigs WithholdingTaxConfig[]
  internalReconciliations InternalReconciliation[]
  advancePayments    AdvancePayment[]
  userDefinedTables  UserDefinedTable[]
  authorizationGroups AuthorizationGroup[]
  inventoryValuations InventoryValuation[]
  goodsTransactions  GoodsTransaction[]
  productionOrders   ProductionOrder[]
  returnRequests     ReturnRequest[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  code           String
  address        String?
  city           String?
  phone          String?
  email          String?
  isHeadOffice   Boolean  @default(false) @map("is_head_office")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments      Department[]
  employees        Employee[]
  userRoles        UserRole[]
  paddyPurchases   PaddyPurchase[]
  productionBatches ProductionBatch[]
  warehouses       Warehouse[]
  salesOrders      SalesOrder[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("branches")
}

model Department {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid
  name           String
  code           String
  headUserId     String?  @map("head_user_id") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  headUser     User?        @relation("DepartmentHead", fields: [headUserId], references: [id])
  employees    Employee[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  phone          String?
  avatarUrl      String?   @map("avatar_url")
  organizationId String    @map("organization_id") @db.Uuid
  isSuperAdmin   Boolean   @default(false) @map("is_superadmin")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles         UserRole[]
  sessions          UserSession[]
  headOfDepartments Department[]     @relation("DepartmentHead")
  employee          Employee?
  auditLogs         AuditLog[]
  notifications     Notification[]
  emailMessages           EmailMessage[]
  conversationsCreated    Conversation[]              @relation("ConversationsCreated")
  conversationParticipants ConversationParticipant[]
  messagesSent            ConversationMessage[]       @relation("MessagesSent")
  announcementsCreated    Announcement[]              @relation("AnnouncementsCreated")
  gatePassApprovals       GatePass[]                  @relation("GatePassApprover")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Role {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  slug           String
  description    String?
  isSystemRole   Boolean @default(false) @map("is_system_role")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String @id @default(uuid()) @db.Uuid
  module      String
  entity      String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@unique([module, entity, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId   String @map("user_id") @db.Uuid
  roleId   String @map("role_id") @db.Uuid
  branchId String? @map("branch_id") @db.Uuid

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("user_sessions")
}

// ============================================================================
// HR & PAYROLL
// ============================================================================

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  DAILY_WAGE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SalarySlipStatus {
  DRAFT
  CONFIRMED
  PAID
  CANCELLED
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  DEDUCTED
}

model Employee {
  id              String         @id @default(uuid()) @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  branchId        String?        @map("branch_id") @db.Uuid
  departmentId    String?        @map("department_id") @db.Uuid
  userId          String?        @unique @map("user_id") @db.Uuid
  employeeCode    String         @map("employee_code")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  phone           String?
  email           String?
  cnic            String?
  designation     String?
  employmentType  EmploymentType @default(FULL_TIME) @map("employment_type")
  joinDate        DateTime       @map("join_date") @db.Date
  exitDate        DateTime?      @map("exit_date") @db.Date
  baseSalary      Decimal        @default(0) @map("base_salary") @db.Decimal(18, 4)
  bankAccount     String?        @map("bank_account")
  bankName        String?        @map("bank_name")
  address         String?
  emergencyContact String?       @map("emergency_contact")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch?            @relation(fields: [branchId], references: [id])
  department       Department?        @relation(fields: [departmentId], references: [id])
  user             User?              @relation(fields: [userId], references: [id])
  attendanceRecords AttendanceRecord[]
  leaveRequests    LeaveRequest[]
  salarySlips      SalarySlip[]
  advances         EmployeeAdvance[]
  expenseClaims    ExpenseClaim[]
  documents        EmployeeDocument[]
  loans            EmployeeLoan[]
  performanceReviews PerformanceReview[]
  finalSettlements FinalSettlement[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@map("employees")
}

model AttendanceRecord {
  id            String           @id @default(uuid()) @db.Uuid
  employeeId    String           @map("employee_id") @db.Uuid
  date          DateTime         @db.Date
  checkIn       DateTime?        @map("check_in")
  checkOut      DateTime?        @map("check_out")
  status        AttendanceStatus @default(PRESENT)
  overtimeHours Decimal?         @map("overtime_hours") @db.Decimal(5, 2)
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@map("attendance_records")
}

model LeaveType {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  daysAllowed    Int     @map("days_allowed")
  isPaid         Boolean @default(true) @map("is_paid")
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]

  @@map("leave_types")
}

model LeaveRequest {
  id          String      @id @default(uuid()) @db.Uuid
  employeeId  String      @map("employee_id") @db.Uuid
  leaveTypeId String      @map("leave_type_id") @db.Uuid
  fromDate    DateTime    @map("from_date") @db.Date
  toDate      DateTime    @map("to_date") @db.Date
  days        Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?     @map("approved_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])
  @@map("leave_requests")
}

model SalarySlip {
  id             String           @id @default(uuid()) @db.Uuid
  employeeId     String           @map("employee_id") @db.Uuid
  month          Int
  year           Int
  baseSalary     Decimal          @map("base_salary") @db.Decimal(18, 4)
  allowances     Json?            @default("{}") 
  deductions     Json?            @default("{}")
  overtimeAmount Decimal          @default(0) @map("overtime_amount") @db.Decimal(18, 4)
  grossSalary    Decimal          @default(0) @map("gross_salary") @db.Decimal(18, 4)
  netSalary      Decimal          @default(0) @map("net_salary") @db.Decimal(18, 4)
  status         SalarySlipStatus @default(DRAFT)
  paidAt         DateTime?        @map("paid_at")
  journalEntryId String?          @map("journal_entry_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@map("salary_slips")
}

model EmployeeAdvance {
  id         String        @id @default(uuid()) @db.Uuid
  employeeId String        @map("employee_id") @db.Uuid
  amount     Decimal       @db.Decimal(18, 4)
  reason     String?
  status     AdvanceStatus @default(PENDING)
  approvedBy String?       @map("approved_by") @db.Uuid
  deductedInSlipId String? @map("deducted_in_slip_id") @db.Uuid
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_advances")
}

// ============================================================================
// FINANCE & ACCOUNTS
// ============================================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  INCOME
  EXPENSE
}

enum BalanceType {
  DEBIT
  CREDIT
}

enum JournalEntryType {
  MANUAL
  SYSTEM
  ADJUSTMENT
  OPENING
  DEPRECIATION
  CREDIT_NOTE
  DEBIT_NOTE
  REVERSAL
  EXPENSE
  PURCHASE
  SALE
  SALARY
  RECEIPT
  PAYMENT
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum VoucherStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERPAID
}

model FiscalYear {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  isActive       Boolean  @default(true) @map("is_active")
  isClosed       Boolean  @default(false) @map("is_closed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  budgets        Budget[]

  @@index([organizationId])
  @@map("fiscal_years")
}

model ChartOfAccount {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  code           String
  name           String
  accountType    AccountType @map("account_type")
  parentId       String?     @map("parent_id") @db.Uuid
  isGroup        Boolean     @default(false) @map("is_group")
  isSystem       Boolean     @default(false) @map("is_system")
  balanceType    BalanceType @map("balance_type")
  openingBalance Decimal     @default(0) @map("opening_balance") @db.Decimal(18, 4)
  description    String?
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent            ChartOfAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children          ChartOfAccount[]   @relation("AccountHierarchy")
  journalEntryLines JournalEntryLine[]
  bankAccounts      BankAccount[]
  taxConfigurations TaxConfiguration[]
  budgetLines       BudgetLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  entryNumber    String           @map("entry_number")
  date           DateTime         @db.Date
  reference      String?
  narration      String?
  entryType      JournalEntryType @default(MANUAL) @map("entry_type")
  fiscalYearId   String           @map("fiscal_year_id") @db.Uuid
  isPosted       Boolean          @default(false) @map("is_posted")
  postedBy       String?          @map("posted_by") @db.Uuid
  postedAt       DateTime?        @map("posted_at")
  createdBy      String?          @map("created_by") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fiscalYear         FiscalYear           @relation(fields: [fiscalYearId], references: [id])
  lines              JournalEntryLine[]
  salarySlips        SalarySlip[]
  paymentVouchers    PaymentVoucher[]
  receiptVouchers    ReceiptVoucher[]
  paddyPurchases     PaddyPurchase[]
  salesInvoices      SalesInvoice[]
  stockAdjustments   StockAdjustment[]
  expenseClaims      ExpenseClaim[]
  creditNotes        CreditNote[]
  debitNotes         DebitNote[]
  purchaseReturns    PurchaseReturn[]
  salesReturns       SalesReturn[]
  assetDepreciations AssetDepreciation[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId, date])
  @@index([fiscalYearId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String  @id @default(uuid()) @db.Uuid
  journalEntryId String  @map("journal_entry_id") @db.Uuid
  accountId      String  @map("account_id") @db.Uuid
  debit          Decimal @default(0) @db.Decimal(18, 4)
  credit         Decimal @default(0) @db.Decimal(18, 4)
  narration      String?
  costCenter     String? @map("cost_center")
  createdAt      DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

model BankAccount {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  accountName    String  @map("account_name")
  bankName       String  @map("bank_name")
  accountNumber  String  @map("account_number")
  branchCode     String? @map("branch_code")
  iban           String?
  accountId      String  @map("account_id") @db.Uuid
  openingBalance Decimal @default(0) @map("opening_balance") @db.Decimal(18, 4)
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account            ChartOfAccount      @relation(fields: [accountId], references: [id])
  paymentVouchers    PaymentVoucher[]
  receiptVouchers    ReceiptVoucher[]
  reconciliations    BankReconciliation[]
  cheques            Cheque[]

  @@index([organizationId])
  @@map("bank_accounts")
}

model PaymentVoucher {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  voucherNumber  String        @map("voucher_number")
  date           DateTime      @db.Date
  partyType      String        @map("party_type")
  partyId        String        @map("party_id") @db.Uuid
  amount         Decimal       @db.Decimal(18, 4)
  paymentMode    PaymentMode   @map("payment_mode")
  bankAccountId  String?       @map("bank_account_id") @db.Uuid
  chequeNumber   String?       @map("cheque_number")
  reference      String?
  narration      String?
  journalEntryId String?       @map("journal_entry_id") @db.Uuid
  status         VoucherStatus @default(DRAFT)
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount?  @relation(fields: [bankAccountId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([organizationId, voucherNumber])
  @@index([organizationId, date])
  @@map("payment_vouchers")
