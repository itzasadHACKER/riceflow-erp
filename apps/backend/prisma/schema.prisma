  RETAILER
  EXPORTER
  WHOLESALE
  WALK_IN
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum DispatchStatus {
  PENDING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  company        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  customerType   CustomerType @default(DEALER) @map("customer_type")
  cnic           String?
  ntn            String?
