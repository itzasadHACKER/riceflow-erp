}

enum CommunicationChannel {
  PHONE
  EMAIL
  WHATSAPP
  VISIT
  SMS
}

enum FollowUpStatus {
  PENDING
  DONE
  OVERDUE
  CANCELLED
}

model Lead {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  name           String
  company        String?
  phone          String?
  email          String?
  source         LeadSource @default(WALK_IN)
  status         LeadStatus @default(NEW)
  assignedTo     String?    @map("assigned_to") @db.Uuid
  notes          String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("leads")
}

model Broker {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  phone          String?
  email          String?
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 2)
  address        String?
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paddyPurchases PaddyPurchase[]

  @@index([organizationId])
  @@map("brokers")
}

model CommunicationLog {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  contactType    String               @map("contact_type")
  contactId      String               @map("contact_id") @db.Uuid
  channel        CommunicationChannel
  subject        String?
  content        String?
  loggedBy       String?              @map("logged_by") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  followUps    FollowUp[]

  @@index([organizationId])
  @@index([contactType, contactId])
  @@map("communication_logs")
}

model FollowUp {
  id                 String         @id @default(uuid()) @db.Uuid
  communicationLogId String         @map("communication_log_id") @db.Uuid
  dueDate            DateTime       @map("due_date") @db.Date
  status             FollowUpStatus @default(PENDING)
  assignedTo         String?        @map("assigned_to") @db.Uuid
  notes              String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  communicationLog CommunicationLog @relation(fields: [communicationLogId], references: [id], onDelete: Cascade)

  @@index([communicationLogId])
  @@map("follow_ups")
}

// ============================================================================
// SYSTEM & AUDIT
// ============================================================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  userId         String?     @map("user_id") @db.Uuid
  entityType     String      @map("entity_type")
  entityId       String      @map("entity_id") @db.Uuid
  action         AuditAction
  oldValues      Json?       @map("old_values")
  newValues      Json?       @map("new_values")
  ipAddress      String?     @map("ip_address")
  userAgent      String?     @map("user_agent")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  title          String
  message        String
  type           String   @default("INFO")
  referenceType  String?  @map("reference_type")
  referenceId    String?  @map("reference_id") @db.Uuid
  isRead         Boolean  @default(false) @map("is_read")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([organizationId])
  @@map("notifications")
}

model SystemSetting {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  key            String
  value          Json
  category       String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("system_settings")
}

model FileAttachment {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  entityType     String  @map("entity_type")
  entityId       String  @map("entity_id") @db.Uuid
  fileName       String  @map("file_name")
  filePath       String  @map("file_path")
  fileSize       Int     @map("file_size")
  mimeType       String  @map("mime_type")
  uploadedBy     String? @map("uploaded_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([organizationId])
  @@map("file_attachments")
}
