// INVENTORY & WAREHOUSING
// ============================================================================

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

model Warehouse {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  branchId       String? @map("branch_id") @db.Uuid
  name           String
  code           String
  address        String?
  capacity       Decimal? @db.Decimal(18, 2)
  capacityUnit   String?  @default("TON") @map("capacity_unit")
  managerId      String?  @map("manager_id") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch?          @relation(fields: [branchId], references: [id])
  inventoryItems   InventoryItem[]
  stockMovementsFrom StockMovement[] @relation("SourceWarehouse")
  stockMovementsTo   StockMovement[] @relation("DestinationWarehouse")
  stockAdjustments StockAdjustment[]
  salesOrderItems  SalesOrderItem[]
  deliveryChallans DeliveryChallan[]
  goodsReceipts    GoodsReceipt[]
  zones            WarehouseZone[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("warehouses")
}

model InventoryItem {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  warehouseId    String       @map("warehouse_id") @db.Uuid
  riceVarietyId  String       @map("rice_variety_id") @db.Uuid
  lotNumber      String?      @map("lot_number")
  batchNumber    String?      @map("batch_number")
  quantity       Decimal      @db.Decimal(18, 4)
  unit           String       @default("KG")
  bagCount       Int?         @map("bag_count")
  bagWeight      Decimal?     @map("bag_weight") @db.Decimal(10, 2)
  qualityGrade   QualityGrade? @map("quality_grade")
  moisture       Decimal?     @db.Decimal(5, 2)
  valuationRate  Decimal      @default(0) @map("valuation_rate") @db.Decimal(18, 4)
  totalValue     Decimal      @default(0) @map("total_value") @db.Decimal(18, 4)
  barcode        String?
  qrCode         String?      @map("qr_code")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  riceVariety  RiceVariety  @relation(fields: [riceVarietyId], references: [id])

  @@index([organizationId])
  @@index([warehouseId])
  @@index([riceVarietyId])
  @@index([barcode])
  @@map("inventory_items")
}

model StockMovement {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @map("organization_id") @db.Uuid
  movementType           MovementType @map("movement_type")
  sourceWarehouseId      String?      @map("source_warehouse_id") @db.Uuid
  destinationWarehouseId String?      @map("destination_warehouse_id") @db.Uuid
  riceVarietyId          String?      @map("rice_variety_id") @db.Uuid
  quantity               Decimal      @db.Decimal(18, 4)
  unit                   String       @default("KG")
  referenceType          String?      @map("reference_type")
  referenceId            String?      @map("reference_id") @db.Uuid
  movementDate           DateTime     @map("movement_date") @db.Date
  narration              String?
  createdBy              String?      @map("created_by") @db.Uuid
  createdAt              DateTime     @default(now()) @map("created_at")

  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceWarehouse      Warehouse?   @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destinationWarehouse Warehouse?   @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])

  @@index([organizationId, movementDate])
  @@index([sourceWarehouseId])
  @@index([destinationWarehouseId])
  @@map("stock_movements")
}

model StockAdjustment {
  id               String  @id @default(uuid()) @db.Uuid
  organizationId   String  @map("organization_id") @db.Uuid
  warehouseId      String  @map("warehouse_id") @db.Uuid
  adjustmentNumber String  @map("adjustment_number")
  date             DateTime @db.Date
  reason           String?
  riceVarietyId    String? @map("rice_variety_id") @db.Uuid
  quantityChange   Decimal @map("quantity_change") @db.Decimal(18, 4)
  previousQuantity Decimal @map("previous_quantity") @db.Decimal(18, 4)
  newQuantity      Decimal @map("new_quantity") @db.Decimal(18, 4)
  approvedBy       String? @map("approved_by") @db.Uuid
  journalEntryId   String? @map("journal_entry_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([organizationId, adjustmentNumber])
  @@index([organizationId])
  @@map("stock_adjustments")
}

