enum CustomerType {
  DEALER
  RETAILER
  EXPORTER
  WHOLESALE
  WALK_IN
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum DispatchStatus {
  PENDING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  company        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  customerType   CustomerType @default(DEALER) @map("customer_type")
  cnic           String?
  ntn            String?
  creditLimit    Decimal      @default(0) @map("credit_limit") @db.Decimal(18, 4)
  openingBalance Decimal      @default(0) @map("opening_balance") @db.Decimal(18, 4)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrders      SalesOrder[]
  salesInvoices    SalesInvoice[]
  deliveryChallans DeliveryChallan[]

  @@index([organizationId])
  @@map("customers")
}

model SalesOrder {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  branchId       String      @map("branch_id") @db.Uuid
  orderNumber    String      @map("order_number")
  date           DateTime    @db.Date
  customerId     String      @map("customer_id") @db.Uuid
  status         OrderStatus @default(DRAFT)
  totalAmount    Decimal     @default(0) @map("total_amount") @db.Decimal(18, 4)
  discount       Decimal     @default(0) @db.Decimal(18, 4)
  taxAmount      Decimal     @default(0) @map("tax_amount") @db.Decimal(18, 4)
  netAmount      Decimal     @default(0) @map("net_amount") @db.Decimal(18, 4)
  deliveryDate   DateTime?   @map("delivery_date") @db.Date
  notes          String?
  createdBy      String?     @map("created_by") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch            @relation(fields: [branchId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  items            SalesOrderItem[]
  salesInvoices    SalesInvoice[]
  deliveryChallans DeliveryChallan[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, date])
  @@index([customerId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id            String  @id @default(uuid()) @db.Uuid
  salesOrderId  String  @map("sales_order_id") @db.Uuid
  riceVarietyId String  @map("rice_variety_id") @db.Uuid
  quantity      Decimal @db.Decimal(18, 4)
  unit          String  @default("KG")
  rate          Decimal @db.Decimal(18, 4)
  amount        Decimal @db.Decimal(18, 4)
  lotNumber     String? @map("lot_number")
  warehouseId   String? @map("warehouse_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  salesOrder  SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  riceVariety RiceVariety @relation(fields: [riceVarietyId], references: [id])
  warehouse   Warehouse?  @relation(fields: [warehouseId], references: [id])

  @@index([salesOrderId])
  @@map("sales_order_items")
}

model SalesInvoice {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  invoiceNumber  String        @map("invoice_number")
  date           DateTime      @db.Date
  salesOrderId   String?       @map("sales_order_id") @db.Uuid
  customerId     String        @map("customer_id") @db.Uuid
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(18, 4)
  discount       Decimal       @default(0) @db.Decimal(18, 4)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(18, 4)
  netAmount      Decimal       @default(0) @map("net_amount") @db.Decimal(18, 4)
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  dueDate        DateTime?     @map("due_date") @db.Date
  journalEntryId String?       @map("journal_entry_id") @db.Uuid
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

