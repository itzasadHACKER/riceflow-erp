  recoveryPercentage  Decimal? @map("recovery_percentage") @db.Decimal(5, 2)
  brokenRatio         Decimal? @map("broken_ratio") @db.Decimal(5, 2)
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  batch ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("milling_records")
}

