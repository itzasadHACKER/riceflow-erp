model StockMovement {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @map("organization_id") @db.Uuid
  movementType           MovementType @map("movement_type")
  sourceWarehouseId      String?      @map("source_warehouse_id") @db.Uuid
