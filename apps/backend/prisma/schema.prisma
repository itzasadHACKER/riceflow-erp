// ============================================================================
// RICE PROCUREMENT
// ============================================================================

enum SupplierType {
  FARMER
  DEALER
  COMMISSION_AGENT
  ARTHI
}

enum RiceCategory {
  BASMATI
  NON_BASMATI
  SELLA
  STEAM
  PARBOILED
  BROKEN
  OTHER
}

enum RiceType {
  PADDY
  RICE
}

enum QualityGrade {
  A_PLUS
  A
  B
  C
  REJECT
}

model Supplier {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  company        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  cnic           String?
  ntn            String?
  supplierType   SupplierType @default(FARMER) @map("supplier_type")
  creditLimit    Decimal      @default(0) @map("credit_limit") @db.Decimal(18, 4)
  openingBalance Decimal      @default(0) @map("opening_balance") @db.Decimal(18, 4)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paddyPurchases   PaddyPurchase[]
  debitNotes       DebitNote[]
  purchaseReturns  PurchaseReturn[]
  purchaseOrders   PurchaseOrder[]
  goodsReceipts    GoodsReceipt[]
  purchaseQuotations PurchaseQuotation[]

  @@index([organizationId])
  @@map("suppliers")
}

model RiceVariety {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  name            String
  code            String
  riceType        RiceType     @map("rice_type")
  category        RiceCategory
  defaultMoisture Decimal?     @map("default_moisture") @db.Decimal(5, 2)
  description     String?
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paddyPurchases     PaddyPurchase[]
  purchaseRates      PurchaseRate[]
  productionBatches  ProductionBatch[]   @relation("InputVariety")
  productionOutputs  ProductionOutput[]  @relation("OutputVariety")
  inventoryItems     InventoryItem[]
  salesOrderItems    SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  quotationItems     QuotationItem[]
  bomOutputs         BillOfMaterial[]    @relation("BOMOutput")
  bomInputs          BillOfMaterialItem[] @relation("BOMInput")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("rice_varieties")
}

model PaddyPurchase {
  id                   String        @id @default(uuid()) @db.Uuid
  organizationId       String        @map("organization_id") @db.Uuid
  branchId             String        @map("branch_id") @db.Uuid
  purchaseNumber       String        @map("purchase_number")
  date                 DateTime      @db.Date
  supplierId           String        @map("supplier_id") @db.Uuid
  riceVarietyId        String        @map("rice_variety_id") @db.Uuid
  brokerId             String?       @map("broker_id") @db.Uuid
  grossWeight          Decimal       @map("gross_weight") @db.Decimal(18, 4)
  tareWeight           Decimal       @default(0) @map("tare_weight") @db.Decimal(18, 4)
  netWeight            Decimal       @map("net_weight") @db.Decimal(18, 4)
  moisturePercentage   Decimal?      @map("moisture_percentage") @db.Decimal(5, 2)
  deductionPercentage  Decimal?      @map("deduction_percentage") @db.Decimal(5, 2)
  finalWeight          Decimal       @map("final_weight") @db.Decimal(18, 4)
  ratePerUnit          Decimal       @map("rate_per_unit") @db.Decimal(18, 4)
  grossAmount          Decimal       @map("gross_amount") @db.Decimal(18, 4)
  deductions           Json?         @default("{}") 
  netAmount            Decimal       @map("net_amount") @db.Decimal(18, 4)
  qualityGrade         QualityGrade? @map("quality_grade")
  lotNumber            String?       @map("lot_number")
  vehicleNumber        String?       @map("vehicle_number")
  gatePassNumber       String?       @map("gate_pass_number")
  paymentStatus        PaymentStatus @default(UNPAID) @map("payment_status")
  journalEntryId       String?       @map("journal_entry_id") @db.Uuid
  notes                String?
  createdBy            String?       @map("created_by") @db.Uuid
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  deletedAt            DateTime?     @map("deleted_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch          @relation(fields: [branchId], references: [id])
  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  riceVariety     RiceVariety     @relation(fields: [riceVarietyId], references: [id])
  broker          Broker?         @relation(fields: [brokerId], references: [id])
  journalEntry    JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  qualityTests    QualityTest[]
  debitNotes      DebitNote[]
  purchaseReturns PurchaseReturn[]

  @@unique([organizationId, purchaseNumber])
  @@index([organizationId, date])
  @@index([supplierId])
  @@map("paddy_purchases")
}

model QualityTest {
  id              String   @id @default(uuid()) @db.Uuid
  paddyPurchaseId String   @map("paddy_purchase_id") @db.Uuid
  testDate        DateTime @map("test_date") @db.Date
  moisture        Decimal? @db.Decimal(5, 2)
  brokenPercentage Decimal? @map("broken_percentage") @db.Decimal(5, 2)
  foreignMatter   Decimal? @map("foreign_matter") @db.Decimal(5, 2)
  chalkyGrains    Decimal? @map("chalky_grains") @db.Decimal(5, 2)
  damagedGrains   Decimal? @map("damaged_grains") @db.Decimal(5, 2)
  grade           QualityGrade?
  testedBy        String?  @map("tested_by")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  paddyPurchase PaddyPurchase @relation(fields: [paddyPurchaseId], references: [id], onDelete: Cascade)

  @@index([paddyPurchaseId])
  @@map("quality_tests")
}

model PurchaseRate {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  riceVarietyId  String    @map("rice_variety_id") @db.Uuid
  rate           Decimal   @db.Decimal(18, 4)
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  effectiveTo    DateTime? @map("effective_to") @db.Date
  minMoisture    Decimal?  @map("min_moisture") @db.Decimal(5, 2)
  maxMoisture    Decimal?  @map("max_moisture") @db.Decimal(5, 2)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  riceVariety  RiceVariety  @relation(fields: [riceVarietyId], references: [id])

  @@index([organizationId])
  @@map("purchase_rates")
}

// ============================================================================
// PRODUCTION MANAGEMENT
// ============================================================================

enum ProcessType {
  SHELLING
  POLISHING
  SELLA
  STEAM
  SORTING
  GRADING
  CLEANING
}

enum BatchStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionBatch {
  id              String      @id @default(uuid()) @db.Uuid
  organizationId  String      @map("organization_id") @db.Uuid
  branchId        String      @map("branch_id") @db.Uuid
  batchNumber     String      @map("batch_number")
  date            DateTime    @db.Date
  inputVarietyId  String      @map("input_variety_id") @db.Uuid
  inputLotNumber  String?     @map("input_lot_number")
  inputWeight     Decimal     @map("input_weight") @db.Decimal(18, 4)
  processType     ProcessType @map("process_type")
  status          BatchStatus @default(PLANNED)
  startedAt       DateTime?   @map("started_at")
  completedAt     DateTime?   @map("completed_at")
  notes           String?
  createdBy       String?     @map("created_by") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch             @relation(fields: [branchId], references: [id])
  inputVariety RiceVariety        @relation("InputVariety", fields: [inputVarietyId], references: [id])
  outputs      ProductionOutput[]
  costs        ProductionCost[]
  millingRecords MillingRecord[]

  @@unique([organizationId, batchNumber])
  @@index([organizationId, date])
  @@map("production_batches")
}

model ProductionOutput {
  id                  String       @id @default(uuid()) @db.Uuid
  batchId             String       @map("batch_id") @db.Uuid
  outputVarietyId     String       @map("output_variety_id") @db.Uuid
  outputWeight        Decimal      @map("output_weight") @db.Decimal(18, 4)
  recoveryPercentage  Decimal?     @map("recovery_percentage") @db.Decimal(5, 2)
  grade               QualityGrade?
  lotNumber           String?      @map("lot_number")
  notes               String?
  createdAt           DateTime     @default(now()) @map("created_at")

  batch         ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  outputVariety RiceVariety     @relation("OutputVariety", fields: [outputVarietyId], references: [id])

  @@index([batchId])
  @@map("production_outputs")
}

model ProductionCost {
  id          String  @id @default(uuid()) @db.Uuid
  batchId     String  @map("batch_id") @db.Uuid
  costType    String  @map("cost_type")
  description String?
  amount      Decimal @db.Decimal(18, 4)
  createdAt   DateTime @default(now()) @map("created_at")

  batch ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("production_costs")
}

model MillingRecord {
  id                  String  @id @default(uuid()) @db.Uuid
  batchId             String  @map("batch_id") @db.Uuid
  paddyInputWeight    Decimal @map("paddy_input_weight") @db.Decimal(18, 4)
  riceOutputWeight    Decimal @map("rice_output_weight") @db.Decimal(18, 4)
  brokenOutputWeight  Decimal @default(0) @map("broken_output_weight") @db.Decimal(18, 4)
  huskWeight          Decimal @default(0) @map("husk_weight") @db.Decimal(18, 4)
  branWeight          Decimal @default(0) @map("bran_weight") @db.Decimal(18, 4)
  recoveryPercentage  Decimal? @map("recovery_percentage") @db.Decimal(5, 2)
  brokenRatio         Decimal? @map("broken_ratio") @db.Decimal(5, 2)
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  batch ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("milling_records")
}

