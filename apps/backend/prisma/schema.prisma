  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  riceVariety  RiceVariety  @relation(fields: [riceVarietyId], references: [id])

  @@index([organizationId])
  @@index([warehouseId])
  @@index([riceVarietyId])
  @@index([barcode])
  @@map("inventory_items")
}

model StockMovement {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @map("organization_id") @db.Uuid
  movementType           MovementType @map("movement_type")
  sourceWarehouseId      String?      @map("source_warehouse_id") @db.Uuid
  destinationWarehouseId String?      @map("destination_warehouse_id") @db.Uuid
  riceVarietyId          String?      @map("rice_variety_id") @db.Uuid
  quantity               Decimal      @db.Decimal(18, 4)
  unit                   String       @default("KG")
  referenceType          String?      @map("reference_type")
  referenceId            String?      @map("reference_id") @db.Uuid
  movementDate           DateTime     @map("movement_date") @db.Date
  narration              String?
  createdBy              String?      @map("created_by") @db.Uuid
  createdAt              DateTime     @default(now()) @map("created_at")

  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceWarehouse      Warehouse?   @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destinationWarehouse Warehouse?   @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])

  @@index([organizationId, movementDate])
  @@index([sourceWarehouseId])
  @@index([destinationWarehouseId])
  @@map("stock_movements")
}

model StockAdjustment {
  id               String  @id @default(uuid()) @db.Uuid
  organizationId   String  @map("organization_id") @db.Uuid
  warehouseId      String  @map("warehouse_id") @db.Uuid
  adjustmentNumber String  @map("adjustment_number")
  date             DateTime @db.Date
  reason           String?
  riceVarietyId    String? @map("rice_variety_id") @db.Uuid
  quantityChange   Decimal @map("quantity_change") @db.Decimal(18, 4)
  previousQuantity Decimal @map("previous_quantity") @db.Decimal(18, 4)
  newQuantity      Decimal @map("new_quantity") @db.Decimal(18, 4)
  approvedBy       String? @map("approved_by") @db.Uuid
  journalEntryId   String? @map("journal_entry_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([organizationId, adjustmentNumber])
  @@index([organizationId])
  @@map("stock_adjustments")
}

