# =============================================================
# Grainix ERP — Backend Configuration
# =============================================================
# Copy this file to .env and update DATABASE_URL with your
# PostgreSQL password:
#   cp .env.example .env
#   Then edit .env and change YOUR_PASSWORD below
# =============================================================

# Database — Replace YOUR_PASSWORD with your PostgreSQL password
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/grainix_erp?schema=public"

# JWT (these defaults work for local development)
JWT_SECRET="grainix-local-dev-jwt-secret-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="grainix-local-dev-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=4000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000
